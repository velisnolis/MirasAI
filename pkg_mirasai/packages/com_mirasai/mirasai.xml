<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>com_mirasai</name>
    <version>0.4.1</version>
    <creationDate>2026-03-24</creationDate>
    <author>Alex Miras</author>
    <authorEmail>alex@miras.pro</authorEmail>
    <description>MirasAI: MCP server for Joomla. AI-powered content translation and management.</description>
    <namespace path="src">Mirasai\Component\Mirasai</namespace>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install/mysql.sql</file>
        </sql>
    </install>

    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>

    <administration>
        <menu>MirasAI</menu>
        <submenu>
            <menu link="option=com_mirasai&amp;view=dashboard">Dashboard</menu>
            <menu link="option=com_mirasai&amp;view=elevation">Elevation</menu>
        </submenu>
        <files>
            <folder>language</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
        </files>
    </administration>

    <config>
        <fields name="params">
            <fieldset name="basic" label="MirasAI">
                <field
                    name="environment_override"
                    type="list"
                    label="Environment"
                    description="Controls whether destructive tools are treated as production-gated or staging-allowed."
                    default="production"
                >
                    <option value="production">Production</option>
                    <option value="staging">Staging</option>
                </field>
            </fieldset>
        </fields>
    </config>

    <api>
        <files folder="api">
            <folder>services</folder>
            <folder>src</folder>
        </files>
    </api>
</extension>
